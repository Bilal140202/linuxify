{
  "name": "linuxify",
  "version": "0.1.0-alpha.2",
  "description": "Run Linux developer tools on Android — compatibility layer, package manager, and diagnostic engine",
  "license": "MIT",
  "author": "Bilal140202 <linuxify@example.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bilal140202/linuxify.git"
  },
  "bugs": {
    "url": "https://github.com/Bilal140202/linuxify/issues"
  },
  "homepage": "https://github.com/Bilal140202/linuxify#readme",
  "keywords": [
    "android",
    "termux",
    "proot",
    "linux",
    "cli",
    "developer-tools",
    "package-manager"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "linuxify": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "registry",
    "docs",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm run test"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "zod": "^3.23.8",
    "execa": "^9.3.1",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "inquirer": "^10.1.8",
    "node-fetch": "^3.3.2",
    "toml": "^3.0.0",
    "yaml": "^2.5.0",
    "semver": "^7.6.3",
    "hasha": "^6.0.0",
    "p-limit": "^6.1.0",
    "p-retry": "^6.2.0",
    "p-timeout": "^6.1.3",
    "quickjs-emscripten": "^0.31.0",
    "handlebars": "^4.7.8",
    "i18next": "^23.12.3",
    "i18next-fs-backend": "^2.3.2"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/inquirer": "^9.0.7",
    "@types/semver": "^7.5.8",
    "@typescript-eslint/eslint-plugin": "^8.2.0",
    "@typescript-eslint/parser": "^8.2.0",
    "eslint": "^9.9.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^2.0.5",
    "@vitest/coverage-v8": "^2.0.5",
    "tsx": "^4.17.0"
  }
}
